# ============================================
# Drishti Kavach — Complete Environment Config
# दृष्टि कवच — The Vision Shield
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git!
# ============================================

# ─── Core ─────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Supabase ─────────────────────────────────
SUPABASE_URL=https://tjcgxudgkepiktsgciuu.supabase.co
SUPABASE_ANON_KEY=sb_publishable_FEGinUojedHVEwzz7_foXg_UtfbElC3
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key_from_supabase_dashboard>

# ─── JWT Auth ──────────────────────────────────
JWT_SECRET=<generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_REFRESH_SECRET=<generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ────────────────────────────────
ENCRYPTION_KEY=<generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# ─── Frontend ──────────────────────────────────
FRONTEND_URL=https://drishti-kavach.vercel.app

# ─── Cloudflare Turnstile (CAPTCHA) ────────────
TURNSTILE_SECRET_KEY=<from cloudflare.com/turnstile>

# ─── AI Provider ───────────────────────────────
AI_PROVIDER=groq
GROQ_API_KEY=<from console.groq.com — free>
DEEPSEEK_API_KEY=<optional deepseek key>
DEEPSEEK_API_KEY_BACKUP=<optional backup key>

# ─────────────────────────────────────────────────────────────────────
# 🆓 FREE APIs — All optional, system degrades gracefully without them
# ─────────────────────────────────────────────────────────────────────

# ── Threat Intelligence (Paid keys, generous free tiers) ─────────────

# AbuseIPDB — 1000 checks/day free
# Sign up: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=<your_key>

# GreyNoise — 20k requests/day free
# Sign up: https://www.greynoise.io/
GREYNOISE_API_KEY=<your_key>

# VirusTotal — 500 requests/day free
# Sign up: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=<your_key>

# ── Threat Intelligence (Completely FREE — no key needed) ────────────
# These are already integrated and work out of the box:
# ✅ AlienVault OTX   — https://otx.alienvault.com (no key needed)
# ✅ URLScan.io        — https://urlscan.io (no key for reads)
# ✅ ip-api.com        — geolocation (no key needed)
# ✅ NVD CVE Database  — https://nvd.nist.gov (no key needed)
# ✅ CIRCL CVE Search  — https://cve.circl.lu (no key needed)
# ✅ OSV               — https://osv.dev (no key needed)
# ✅ GitHub Advisories — https://github.com/advisories (no key needed)

# ── HaveIBeenPwned — Breach monitoring ───────────────────────────────
# FREE for domain checks (no key needed for basic use)
# For email checks: https://haveibeenpwned.com/API/Key ($3.50/month)
HIBP_API_KEY=<optional — domain checks work without key>

# ── Cloudflare Edge Protection ────────────────────────────────────────
# Dashboard -> My Profile -> API Tokens -> Create Token
# Permissions: Zone:Firewall Rules:Edit + Zone:Cache Purge
CLOUDFLARE_API_TOKEN=<your_api_token>
CLOUDFLARE_ZONE_ID=<your_zone_id_from_zone_overview>

# ── Alert Channels ────────────────────────────────────────────────────

# Slack (real-time alerts in Slack channel)
# Create at: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram (mobile push alerts)
# 1. Message @BotFather on Telegram: /newbot
# 2. Get your Chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=<your_bot_token>
TELEGRAM_CHAT_ID=<your_chat_id>
