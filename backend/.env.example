# ============================================
# Drishti Kavach — Complete Environment Config
# दृष्टि कवच — The Vision Shield
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git!
# ============================================

# ─── Core ─────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Supabase ─────────────────────────────────
SUPABASE_URL=https://tjcgxudgkepiktsgciuu.supabase.co
SUPABASE_ANON_KEY=sb_publishable_FEGinUojedHVEwzz7_foXg_UtfbElC3
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key_from_supabase_dashboard>

# ─── JWT Auth ──────────────────────────────────
JWT_SECRET=<generate_with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_REFRESH_SECRET=<generate_with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ────────────────────────────────
ENCRYPTION_KEY=<generate_with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# ─── Frontend ──────────────────────────────────
FRONTEND_URL=https://drishti-kavach.vercel.app

# ─── Cloudflare Turnstile (CAPTCHA) ────────────
TURNSTILE_SECRET_KEY=<your_turnstile_secret_from_cloudflare_dashboard>

# ─── AI Provider ───────────────────────────────
AI_PROVIDER=groq
GROQ_API_KEY=<your_groq_api_key_from_console.groq.com>
DEEPSEEK_API_KEY=<your_deepseek_api_key>
DEEPSEEK_API_KEY_BACKUP=<backup_deepseek_key>

# ─── Threat Intelligence APIs ────────────────
# AbuseIPDB — https://www.abuseipdb.com/register (free)
ABUSEIPDB_API_KEY=<your_abuseipdb_key>

# GreyNoise — https://www.greynoise.io/ (free tier)
GREYNOISE_API_KEY=<your_greynoise_key>

# VirusTotal — https://www.virustotal.com/gui/join-us (free)
VIRUSTOTAL_API_KEY=<your_virustotal_key>

# ─── Cloudflare Edge Protection ──────────────
# Dashboard -> API Tokens -> Create Token
# Permissions: Zone:Firewall Rules:Edit + Zone:Cache Purge
CLOUDFLARE_API_TOKEN=<your_cloudflare_api_token>
CLOUDFLARE_ZONE_ID=<your_cloudflare_zone_id>

# ─── Alert Channels ───────────────────────────
# Slack: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram: Message @BotFather to create bot, @userinfobot to get chat ID
TELEGRAM_BOT_TOKEN=<your_bot_token>
TELEGRAM_CHAT_ID=<your_telegram_chat_id>

# ─── Email Alerts (SMTP via Gmail App Password) ──
# Google Account -> Security -> 2FA -> App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=whitehatwolf22@gmail.com
SMTP_PASS=<gmail_app_password_16_chars>
SMTP_FROM=Drishti Kavach <whitehatwolf22@gmail.com>
ADMIN_EMAIL=whitehatwolf22@gmail.com
